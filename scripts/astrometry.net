# 
# Install Astrometry.Net on Raspberry Pi.
# Includes data files for 16-50mm lenses on Hi Quality camera.
sudo apt update
sudo apt upgrade
sudo apt install astrometry.net
sudo apt install astrometry-data-2mass-08-19
 astrometry-data-4207 astrometry-data-4208 \
 astrometry-data-4210 astrometry-data-4211 \
